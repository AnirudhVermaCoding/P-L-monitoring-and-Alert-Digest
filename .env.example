# Copy this file to `.env` and fill in values. `.env` is gitignored — never commit real secrets.
# EVERYTHING WORKS WITH ZERO KEYS. These only enable optional upgrades.

# --- Optional: LLM for phrasing insights (provider auto-detected from the key prefix) ---
# Without any key, the app uses a deterministic template that produces the same facts.
# Put ONE key in XAI_API_KEY below:
#   * A Groq key  (starts with "gsk_") -> uses Groq's free, generous API (Llama models).
#     Get one free at https://console.groq.com/keys . Optional model override: GROQ_MODEL.
#   * An xAI key  (starts with "xai-") -> uses Grok. Get one at https://console.x.ai .
XAI_API_KEY=
XAI_MODEL=grok-4.3
GROQ_MODEL=llama-3.3-70b-versatile

# --- Email delivery mode ---
# outbox = write emails to files under outputs/outbox/ (default, zero-cost, no account needed)
# smtp   = actually send via the SMTP settings below
EMAIL_MODE=outbox

# --- Optional: real SMTP (free path = Gmail app password, port 587) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=pnl-monitor@example.com
