# Copy this file to `.env` and fill in values. `.env` is gitignored — never commit real secrets.
# EVERYTHING WORKS WITH ZERO KEYS. These only enable optional upgrades.

# --- Optional: Grok (x.ai) for LLM-phrased insights ---
# Without this, the app uses a deterministic template that produces the same facts.
# Free credits: sign up at https://console.x.ai (~$25 signup + data-sharing opt-in).
XAI_API_KEY=
XAI_MODEL=grok-4.3

# --- Email delivery mode ---
# outbox = write emails to files under outputs/outbox/ (default, zero-cost, no account needed)
# smtp   = actually send via the SMTP settings below
EMAIL_MODE=outbox

# --- Optional: real SMTP (free path = Gmail app password, port 587) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=pnl-monitor@example.com
